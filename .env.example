# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────
# REQUIRED in production: long random string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional: e-mail granted the "admin" role when it registers.
# OWNER_EMAIL=you@example.com

# Optional: set to "false" to disable self-registration after onboarding.
# The very first account can always be created (to bootstrap the owner).
ALLOW_REGISTRATION=true

# ── Persistence (defaults to ./.data) ───────────────────────────────────────
# All state lives on the local disk — no external database or object storage.
# DATA_DIR=/var/lib/familyoffice
# DATABASE_FILE=/var/lib/familyoffice/app.db
# STORAGE_DIR=/var/lib/familyoffice/uploads

# Optional: max upload size in bytes (default 16 MB).
# MAX_UPLOAD_BYTES=16777216
