# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (MySQL) ────────────────────────────────────────────────────────
# REQUIRED. Connection string for your MySQL/MariaDB database.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/familyoffice

# ── Auth ──────────────────────────────────────────────────────────────────
# REQUIRED in production: long random string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Uploads (stored on local disk; mount a persistent volume in prod) ───────
# DATA_DIR=/var/lib/familyoffice          # base dir (default ./.data)
# STORAGE_DIR=/var/lib/familyoffice/uploads
# MAX_UPLOAD_BYTES=16777216               # 16 MB
